{
  "name": "webpack-react-boilerplate",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DonAdam2/micro-frontend-inner-app"
  },
  "description": "Micro frontend inner app",
  "main": "index.js",
  "browserslist": [
    "last 2 versions",
    "not dead"
  ],
  "scripts": {
    "start": "node scripts/start.js",
    "build": "webpack --config buildTools/webpack.prod.js --progress --color",
    "build:serve": "serve dist --cors -p 8081",
    "analyze-bundle": "yarn build --json=stats.json && webpack-bundle-analyzer stats.json dist"
  },
