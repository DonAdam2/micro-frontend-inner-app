    "@babel/preset-react": "7.28.5",
    "@babel/runtime": "7.29.2",
    "@eslint/js": "9.31.0",
    "babel-loader": "10.1.1",
    "browserslist": "4.28.1",
    "clean-webpack-plugin": "4.0.0",
    "cli-color": "2.0.4",
    "css-loader": "7.1.4",
    "css-minimizer-webpack-plugin": "8.0.0",
    "detect-port": "2.1.0",
    "dotenv-webpack": "9.0.0",
    "eslint": "9.31.0",
    "eslint-config-prettier": "10.1.8",
